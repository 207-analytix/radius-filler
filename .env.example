# Radius Filler — Environment Variable Reference
# Copy this file to .env for local reference ONLY.
# NEVER commit .env or real values to GitHub.
# All server-side secrets are set via: supabase secrets set KEY=value

# --- Frontend (safe to expose — Supabase anon key is public by design) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# --- Edge Functions only (Supabase Vault — never in frontend) ---
GEMINI_API_KEY=your-gemini-api-key
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
